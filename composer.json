{
    "name": "zagrox/mailzila",
    "description": "A modern newsletter platform",
    "version": "1.1.0",
    "type": "project",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-pdo": "*",
        "ext-curl": "*",
        "ext-mysql": "*",
        "elasticemail/elasticemail-php": "^4.0",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
} 